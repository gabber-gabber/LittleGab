<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">

    <FrameLayout
        android:id="@+id/avatar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/conv_avatar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="&gt;_"
            android:textColor="@color/accent"
            android:textStyle="bold"
            android:textSize="16sp"
            android:fontFamily="monospace" />
    </FrameLayout>

    <TextView
        android:id="@+id/itemName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/fg"
        android:textSize="16sp"
        android:textStyle="bold"
        android:singleLine="true"
        android:ellipsize="end"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toTopOf="@id/avatar"
        app:layout_constraintStart_toEndOf="@id/avatar"
        app:layout_constraintEnd_toStartOf="@id/itemBadge"
        tools:text="会话 09:41" />

    <View
        android:id="@+id/itemBadge"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/badge_dot"
        android:visibility="gone"
        android:layout_marginEnd="6dp"
        app:layout_constraintTop_toTopOf="@id/itemName"
        app:layout_constraintBottom_toBottomOf="@id/itemName"
        app:layout_constraintEnd_toStartOf="@id/itemTime" />

    <TextView
        android:id="@+id/itemTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/muted"
        android:textSize="12sp"
        app:layout_constraintTop_toTopOf="@id/itemName"
        app:layout_constraintBottom_toBottomOf="@id/itemName"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="09:41" />

    <TextView
        android:id="@+id/itemPreview"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/muted"
        android:textSize="13sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:fontFamily="monospace"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/itemName"
        app:layout_constraintStart_toStartOf="@id/itemName"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="MARKER-12345" />

</androidx.constraintlayout.widget.ConstraintLayout>
