<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Tailscale IPs (100.64.0.0/10) and private LAN are plain HTTP; user controls both ends. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
