<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="NsLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/muted</item>
        <item name="android:textSize">12sp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="NsOutline" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="hintEnabled">false</item>
    </style>

    <style name="NsField">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/fg</item>
        <item name="android:textColorHint">@color/muted</item>
        <item name="android:singleLine">true</item>
    </style>
</resources>
